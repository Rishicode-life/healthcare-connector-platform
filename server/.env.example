# Server
PORT=3001
NODE_ENV=development

# OpenAI — required for hybrid LLM co-pilot (optional; falls back to rules-only)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=15000

# Set to false to disable LLM calls even when API key is present
AI_LLM_ENABLED=true
